{
    "description": "Double-tap Left Option → Toggle AeroOverlay",
    "manipulators": [
        {
            "type": "basic",
            "from": {
                "key_code": "left_option",
                "modifiers": { "optional": ["any"] }
            },
            "conditions": [
                {
                    "type": "variable_if",
                    "name": "aero_overlay_option_primed",
                    "value": 1
                }
            ],
            "to": [
                {
                    "key_code": "left_option"
                }
            ],
            "to_if_alone": [
                {
                    "shell_command": "/bin/bash -c '$HOME/.local/bin/aero-overlay-toggle'"
                },
                {
                    "set_variable": {
                        "name": "aero_overlay_option_primed",
                        "value": 0
                    }
                }
            ]
        },
        {
            "type": "basic",
            "from": {
                "key_code": "left_option",
                "modifiers": { "optional": ["any"] }
            },
            "to": [
                {
                    "key_code": "left_option"
                }
            ],
            "to_if_alone": [
                {
                    "set_variable": {
                        "name": "aero_overlay_option_primed",
                        "value": 1
                    }
                }
            ],
            "to_delayed_action": {
                "to_if_invoked": [
                    {
                        "set_variable": {
                            "name": "aero_overlay_option_primed",
                            "value": 0
                        }
                    }
                ],
                "to_if_canceled": [
                    {
                        "set_variable": {
                            "name": "aero_overlay_option_primed",
                            "value": 0
                        }
                    }
                ]
            },
            "parameters": {
                "basic.to_delayed_action_delay_milliseconds": 400
            }
        }
    ]
}
